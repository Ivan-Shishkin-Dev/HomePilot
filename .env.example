VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

#Groq Chatbot
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY

# HasData Web Scraping API — enables live Zillow rental search
# Get your key at https://hasdata.com (optional — app falls back to static data without it)
VITE_HASDATA_API_KEY=YOUR_HASDATA_API_KEY

# Livability (listing detail): real crime + rent trend by address
# Optional: FRED API for US rent trend (free key at https://fred.stlouisfed.org/docs/api/api_key.html)
VITE_FRED_API_KEY=YOUR_FRED_API_KEY
# Optional: CrimeoMeter for finer-grained crime stats by lat/lon (https://www.crimeometer.com/)
VITE_CRIMEOMETER_API_KEY=YOUR_CRIMEOMETER_API_KEY

# For Vercel: set these in Project → Settings → Environment Variables, then redeploy.